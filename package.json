{
  "name": "reproguard-itworkshere",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitLab Duo Agent Platform managing project for ReproGuard + ItWorksHere",
  "scripts": {
    "build": "tsc --pretty false --noEmit",
    "demo:bootstrap-plan": "tsx src/demo/bootstrap-plan.ts",
    "demo:golden-path": "tsx src/demo/golden-path.ts",
    "demo:remote-bootstrap": "tsx src/demo/remote-bootstrap.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:full": "npm run build && npm test && npm run demo:golden-path",
    "smoke": "tsx src/index.ts"
  },
  "dependencies": {
    "glob": "^11.0.3",
    "semver": "^7.7.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
